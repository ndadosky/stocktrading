# Copy to .env and adjust before running docker compose.
POSTGRES_USER=stock
POSTGRES_PASSWORD=stockpass
POSTGRES_DB=stocktrading
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Optional full URL instead of POSTGRES_* variables:
# DATABASE_URL=postgresql://stock:change-me@127.0.0.1:5432/stocktrading

HOST=0.0.0.0
PORT=80
STOCK_STARTING_CAPITAL=25000

# On the Pi, point at Codex's Python if you want Pillow from that runtime:
# STOCK_IMAGE_PYTHON=/path/to/codex/python3
