# Copy to .env and adjust before running docker compose.
POSTGRES_USER=stock
POSTGRES_PASSWORD=stockpass
POSTGRES_DB=stocktrading
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Optional full URL instead of POSTGRES_* variables:
# DATABASE_URL=postgresql://stock:change-me@127.0.0.1:5432/stocktrading

HOST=0.0.0.0
PORT=80
STOCK_STARTING_CAPITAL=25000

# Home Controls: PoolSync is queried locally by the app server. Keep credentials
# in .env only; never place the authorization token in browser code or git.
POOLSYNC_URL=http://POOLSYNC_IP/api/poolsync?cmd=poolSync&all=
POOLSYNC_AUTHORIZATION=
POOLSYNC_USER=

# Optional Home Assistant connection and entity IDs for Home Controls.
HOME_ASSISTANT_URL=http://127.0.0.1:8123
HOME_ASSISTANT_TOKEN=
HOME_FRONT_DOOR_ENTITY=
HOME_SOLAR_POWER_ENTITY=
HOME_SOLAR_TODAY_ENTITY=
HOME_KIA_BATTERY_ENTITY=
HOME_KIA_CHARGING_ENTITY=
HOME_VOLVO_BATTERY_ENTITY=
HOME_VOLVO_CHARGING_ENTITY=

# eWeLink PSF-B04-GL channels, exposed through Home Assistant switch entities.
EWELINK_DEVICE_ID=
EWELINK_MODEL=PSF-B04-GL
HOME_EWELINK_CHANNEL_1_ENTITY=
HOME_EWELINK_CHANNEL_1_NAME=Channel 1
HOME_EWELINK_CHANNEL_2_ENTITY=
HOME_EWELINK_CHANNEL_2_NAME=Channel 2
HOME_EWELINK_CHANNEL_3_ENTITY=
HOME_EWELINK_CHANNEL_3_NAME=Channel 3
HOME_EWELINK_CHANNEL_4_ENTITY=
HOME_EWELINK_CHANNEL_4_NAME=Channel 4

# Scheduler: systemd on Pi (default in docker-compose.pi.yml), internal loop for local dev
# STOCK_SCHEDULER=internal

# Pi production: require PostgreSQL ledger (no CSV fallback)
# STOCK_REQUIRE_POSTGRES=true

# On the Pi, point at Codex's Python if you want Pillow from that runtime:
# STOCK_IMAGE_PYTHON=/path/to/codex/python3

# Pi: host Codex standalone binary and config (defaults in docker-compose.pi.yml)
# CODEX_HOST_BIN=/home/admin/.codex/packages/standalone/current/bin/codex
# CODEX_HOST_CONFIG=/home/admin/.codex
